# ─────────────────────────────────────────────────────────────
# Copia este archivo a .env y rellena los valores.
# NUNCA subas .env al repositorio (ya esta en .gitignore).
# ─────────────────────────────────────────────────────────────

# Puerto publico de la web (Nginx)
WEB_PORT=8080

# URL que el frontend usa para llamar a la API.
# En produccion con dominio: https://tudominio.com/api
VITE_API_URL=/api

# ── Backend ──────────────────────────────────────────────────
# Secreto para firmar los JWT. GENERA UNO LARGO Y ALEATORIO.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_aleatorio
JWT_EXPIRES_IN=7d

# Ruta del archivo SQLite (dentro del contenedor)
DATABASE_PATH=/app/data/rus.db

# WhatsApp del administrador (para la pantalla de suscripcion vencida)
# Formato internacional sin + ni espacios. Ej Peru: 51987654321
ADMIN_WHATSAPP=51900000000

# Costo de la suscripcion mostrado al usuario
PRECIO_SUSCRIPCION=15

# Rate limiting del login (intentos por ventana)
LOGIN_RATE_MAX=5
LOGIN_RATE_WINDOW_MIN=15
